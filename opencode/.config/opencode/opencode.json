{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "ruff": {
      "command": [
        "ruff",
        "server"
      ],
      "extensions": [
        ".py"
      ]
    },
    "toml-lsp": {
      "command": [
        "tombi",
        "lsp"
      ],
      "extensions": [
        ".toml"
      ]
    },
    "ty": {
      "command": [
        "ty",
        "server"
      ],
      "extensions": [
        ".py"
      ]
    }
  }
}
