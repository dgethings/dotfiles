{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "basedpyright": {
      "command": [
        "basedpyright-langserver",
        "--stdio"
      ],
      "extensions": [
        ".py"
      ]
    },
    "toml-lsp": {
      "command": [
        "tombi",
        "lsp"
      ],
      "extensions": [
        ".toml"
      ]
    }
  }
}
